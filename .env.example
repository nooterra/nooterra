# Nooterra Environment Variables
# Copy this file to .env and fill in your values

# --- AI Provider (pick one) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...

# --- Optional: Tool Integrations ---
# SLACK_BOT_TOKEN=xoxb-...
# GITHUB_TOKEN=ghp_...
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=you@example.com
# SMTP_PASS=...
# STRIPE_API_KEY=sk_...

# --- Optional: API Server (for hosted deployments) ---
# STORE=pg
# DATABASE_URL=postgres://user:pass@localhost:5432/nooterra
# PROXY_API_PORT=3000
# NODE_ENV=development

# --- Optional: Redis (enables distributed rate limiting across replicas) ---
# REDIS_URL=redis://localhost:6379

# --- Optional: Product Analytics (PostHog) ---
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Optional: Web Search (Brave Search API) ---
# BRAVE_SEARCH_API_KEY=BSA...

# --- Optional: OpenTelemetry tracing ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
