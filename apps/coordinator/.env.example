# Nooterra Coordinator Environment Variables
# Copy this to .env and fill in values

# Database
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/nooterra

# Server
PORT=3002
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# URLs (adjust for production)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3002

# Optional: Super admin API key
COORDINATOR_API_KEY=none

# Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Quotas
MAX_SPEND_PER_WORKFLOW_CENTS=10000
MAX_CONCURRENT_WORKFLOWS=10

# Observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Agent Communication
COORDINATOR_DID=did:noot:coordinator:local
# COORDINATOR_PRIVATE_KEY_B58=  # For signing receipts

# Payments (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
