# Nooterra Coordinator Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================

# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/nooterra
POSTGRES_URL=postgresql://user:password@localhost:5432/nooterra

# JWT signing secret - MUST be set in production (min 32 chars recommended)
JWT_SECRET=generate-a-secure-32-char-secret

# CORS allowed origins (comma-separated for multiple)
# In production, set to your actual domains
CORS_ORIGIN=https://console.nooterra.ai,https://www.nooterra.ai

# =============================================================================
# REGISTRY CONNECTION
# =============================================================================

# Registry service URL
REGISTRY_URL=https://registry.nooterra.ai

# Registry API key for internal calls
REGISTRY_API_KEY=your-registry-api-key

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Webhook signing secret for HMAC signatures
WEBHOOK_SECRET=generate-a-secure-32-char-secret

# Treasury wallet (USDC payments)
TREASURY_ADDRESS=0xYourTreasuryAddress

# =============================================================================
# LLM PLANNER (OPTIONAL)
# =============================================================================

ENABLE_LLM_PLANNER=false
HERMES_BASE_URL=https://api.openai.com/v1
HERMES_API_KEY=sk-xxx
HERMES_MODEL=adamo1139/Hermes-3-Llama-3.1-8B-FP8-Dynamic

# =============================================================================
# STRIPE PAYMENTS (OPTIONAL)
# =============================================================================

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# =============================================================================
# SERVER CONFIG
# =============================================================================

PORT=8002
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# QUOTAS & LIMITS (0 = unlimited)
# =============================================================================

MAX_WORKFLOWS_PER_DAY=0
MAX_CONCURRENT_WORKFLOWS=0
MAX_SPEND_PER_WORKFLOW_CENTS=0

# =============================================================================
# AGENT DISPATCH
# =============================================================================

HEARTBEAT_TTL_MS=60000
DISPATCH_BATCH_MS=1000
DAG_MAX_ATTEMPTS=3
NODE_TIMEOUT_MS=60000

# =============================================================================
# HEALTH MONITORING
# =============================================================================

ENABLE_ALERT_MONITOR=true
ALERT_EVAL_INTERVAL_MS=60000
STUCK_WORKFLOW_THRESHOLD_MS=600000
FAILURE_RATE_THRESHOLD=0.5
FAILURE_MIN_CALLS=5
DLQ_ALERT_THRESHOLD=10

# =============================================================================
# REDIS (OPTIONAL - for queue/caching)
# =============================================================================

# Redis connection URL (Railway, Upstash, or local)
# If not set, falls back to Postgres-based queue (slower but works)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:xxx@your-redis.upstash.io:6379

