{
  "name": "@nooterra/coordinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:dispatcher": "tsx src/dispatcher.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dispatcher": "node dist/dispatcher.js",
    "reconcile:payments": "tsx src/workers/reconcile-payments.ts",
    "migrate": "tsx src/migrate.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.27.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@sentry/node": "^8.34.0",
    "@fastify/cors": "^9.0.1",
    "@nooterra/types": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "base64url": "^3.0.1",
    "bs58": "^5.0.0",
    "cbor": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.7",
    "ethers": "^6.13.4",
    "fastify": "^4.28.1",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "stripe": "^16.6.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/base64url": "^2.0.7",
    "@types/bs58": "^4.0.1",
    "@types/cbor": "^6.0.4",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.7",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
