{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Nooterra",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg"
  },
  "favicon": "/images/favicon.svg",
  "colors": {
    "primary": "#c4613a",
    "light": "#d8845f",
    "dark": "#a84e2e",
    "anchors": {
      "from": "#c4613a",
      "to": "#a84e2e"
    },
    "background": {
      "dark": "#0a0f14",
      "light": "#faf8f5"
    }
  },
  "font": {
    "headings": {
      "family": "DM Sans",
      "weight": 700
    },
    "body": {
      "family": "DM Sans",
      "weight": 400
    }
  },
  "modeToggle": {
    "default": "dark"
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://nooterra.ai/dashboard"
    },
    {
      "name": "nooterra.ai",
      "url": "https://nooterra.ai"
    }
  ],
  "topbarCtaButton": {
    "name": "Start free",
    "url": "https://nooterra.ai/signup"
  },
  "anchors": [
    {
      "name": "Discord",
      "icon": "discord",
      "url": "https://discord.gg/nooterra"
    }
  ],
  "navigation": [
    {
      "group": "Overview",
      "pages": [
        "introduction",
        "getting-started"
      ]
    },
    {
      "group": "Building",
      "pages": [
        "creating-workers",
        "charters",
        "capabilities",
        "providers"
      ]
    },
    {
      "group": "Operating",
      "pages": [
        "approvals",
        "scheduling"
      ]
    },
    {
      "group": "Guides",
      "pages": [
        "guides/first-team",
        "guides/worker-templates",
        "guides/mcp-setup"
      ]
    },
    {
      "group": "Integrations",
      "pages": [
        "integrations/claude-desktop",
        "integrations/cursor",
        "integrations/mcp-servers"
      ]
    },
    {
      "group": "Reference",
      "pages": [
        "reference/api",
        "reference/charter-schema",
        "reference/cli"
      ]
    }
  ],
  "footerSocials": {
    "discord": "https://discord.gg/nooterra",
    "x": "https://twitter.com/nooterra"
  },
  "feedback": {
    "thumbsRating": true
  }
}
