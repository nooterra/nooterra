{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nooterra.local/schemas/EvidenceBundle.v1.schema.json",
  "title": "EvidenceBundle.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "executionGrantId",
    "evidenceRefs",
    "submittedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "EvidenceBundle.v1" },
    "executionGrantId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "workOrderId": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
    "progressId": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
    "eventType": { "type": ["string", "null"], "minLength": 1, "maxLength": 200 },
    "message": { "type": ["string", "null"], "maxLength": 4000 },
    "percentComplete": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "executionAttestationRef": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["attestationId", "attestationHash"],
      "properties": {
        "attestationId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "attestationHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "at": { "type": ["string", "null"], "format": "date-time" },
    "submittedAt": { "type": "string", "format": "date-time" },
    "evidenceBundleHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
