{
  "name": "nooterra",
  "private": true,
  "version": "0.0.0",
  "description": "Nooterra - The coordination protocol for AI agents",
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:coordinator": "pnpm --filter @nooterra/coordinator dev",
    "dev:registry": "pnpm --filter @nooterra/registry dev",
    "dev:console": "pnpm --filter @nooterra/console dev",
    "dev:sandbox": "pnpm --filter @nooterra/sandbox-runner dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
