{
  "name": "@nooterra/types",
  "version": "0.1.0",
  "description": "Shared type definitions for the Nooterra protocol",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "import": "./dist/ledger.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "import": "./dist/policy.js"
    },
    "./capability": {
      "types": "./dist/capability.d.ts",
      "import": "./dist/capability.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nooterra",
    "types",
    "ai-agents",
    "protocol"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
